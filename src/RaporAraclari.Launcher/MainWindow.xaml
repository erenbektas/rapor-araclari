<Window x:Class="RaporAraclari.Launcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:RaporAraclari.Launcher.ViewModels"
        mc:Ignorable="d"
        Title="Rapor Araçları"
        Width="760"
        Height="560"
        MinWidth="640"
        MinHeight="480"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/Assets/icon.ico">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Rapor Araçları"
                           FontSize="20"
                           FontWeight="SemiBold" />
                <TextBlock Margin="0,2,0,0"
                           FontSize="9"
                           Foreground="{StaticResource TextSecondary}"
                           Text="Grup Sigorta Ekspertiz Hizmetleri Limited Şirketi" />
            </StackPanel>

            <TextBlock Grid.Column="1"
                       VerticalAlignment="Center"
                       Foreground="{StaticResource TextSecondary}"
                       Text="{Binding LauncherVersion}" />
        </Grid>

        <Border Grid.Row="1"
                Background="{StaticResource CardBg}"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="20,18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Text="Açmak istediğiniz aracı seçin. Kurulum ve güncellemeler launcher içinden yönetilir."
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="12"
                           TextWrapping="Wrap" />

                <ItemsControl Grid.Row="1"
                              Margin="0,18,0,0"
                              ItemsSource="{Binding Apps}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type viewModels:AppCardViewModel}">
                            <Border Padding="0,18"
                                    BorderBrush="{StaticResource BorderColor}"
                                    BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel MaxWidth="340">
                                        <TextBlock Text="{Binding Definition.DisplayName}"
                                                   FontSize="16"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Text="{Binding Definition.Description}"
                                                   Foreground="{StaticResource TextSecondary}"
                                                   FontSize="12"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="1"
                                                Margin="18,0,0,0"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{Binding InstalledSummary}"
                                                   FontSize="12" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Text="{Binding UpdateSummary}"
                                                   FontSize="12"
                                                   Foreground="{Binding StatusBrush}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="2"
                                                Margin="18,0,0,0"
                                                Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <Button Margin="0,0,8,0"
                                                Padding="16,7"
                                                Content="Güncelle"
                                                Style="{StaticResource AccentButton}"
                                                Command="{Binding DataContext.UpdateAppCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Visibility="{Binding ShowUpdateAction, Converter={StaticResource BoolToVisibilityConverter}}" />

                                        <Button Padding="16,7"
                                                Content="{Binding PrimaryActionText}"
                                                Command="{Binding DataContext.OpenAppCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Visibility="{Binding ShowNeutralPrimaryAction, Converter={StaticResource BoolToVisibilityConverter}}" />

                                        <Button Padding="16,7"
                                                Content="{Binding PrimaryActionText}"
                                                Style="{StaticResource AccentButton}"
                                                Command="{Binding DataContext.OpenAppCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Visibility="{Binding ShowAccentPrimaryAction, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    Margin="0,10,0,5">
            <Button Width="30"
                    Height="30"
                    Padding="0"
                    FontSize="18"
                    VerticalAlignment="Center"
                    Content="ⓘ"
                    ToolTip="Hakkında"
                    Click="BtnInfo_Click"
                    Background="Transparent"
                    Foreground="{StaticResource TextSecondary}" />
        </StackPanel>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,5">
            <Button Content="Güncellemeleri Denetle"
                    Command="{Binding CheckUpdatesCommand}" />
        </StackPanel>

        <StackPanel Grid.Row="3">
            <ProgressBar Margin="0,5,0,5"
                         Value="{Binding ProgressValue}"
                         Minimum="0"
                         Maximum="100"
                         IsIndeterminate="{Binding IsProgressIndeterminate}" />
            <TextBlock Text="{Binding StatusLine}"
                       Foreground="{StaticResource TextSecondary}"
                       FontSize="12" />
        </StackPanel>
    </Grid>
</Window>
