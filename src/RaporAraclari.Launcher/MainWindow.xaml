<Window x:Class="RaporAraclari.Launcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:RaporAraclari.Launcher.ViewModels"
        mc:Ignorable="d"
        Title="Rapor Araçları Launcher"
        Height="760"
        Width="1180"
        MinHeight="680"
        MinWidth="980"
        Background="#FFF7F1">
    <Window.Resources>
        <DropShadowEffect x:Key="CardShadow"
                          BlurRadius="24"
                          ShadowDepth="0"
                          Color="#140F172A"
                          Opacity="0.18" />
    </Window.Resources>
    <Grid Margin="26">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Padding="28"
                Background="#FFFBF8"
                BorderBrush="#F1E7DD"
                BorderThickness="1"
                CornerRadius="28"
                Effect="{StaticResource CardShadow}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Rapor Araçları"
                               FontSize="36"
                               FontFamily="Bahnschrift SemiBold"
                               Foreground="#111827" />
                    <TextBlock Margin="0,10,0,0"
                               Foreground="#475569"
                               FontSize="16"
                               TextWrapping="Wrap"
                               Text="Belge Numaralandırıcı ve Sorumluluk Hesaplayıcı için tek giriş noktası. Kurulum, açılış ve güncellemeler doğrudan launcher içinden yönetilir." />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <TextBlock HorizontalAlignment="Right"
                               Foreground="#64748B"
                               FontSize="13"
                               Text="{Binding LauncherVersion}" />
                    <Button Margin="0,12,0,0"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Content="Güncellemeleri Denetle"
                            Command="{Binding CheckUpdatesCommand}" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Margin="0,22,0,22"
                Padding="18"
                Background="#F8FAFC"
                BorderBrush="#D8E2EC"
                BorderThickness="1"
                CornerRadius="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#0F172A"
                               Text="{Binding StatusMessage}" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="#475569"
                               Text="{Binding StatusDetail}" />
                </StackPanel>

                <Border Grid.Column="1"
                        Padding="12,8"
                        Background="#E2E8F0"
                        CornerRadius="999">
                    <TextBlock Foreground="#334155"
                               FontWeight="SemiBold"
                               Text="{Binding Apps.Count, StringFormat='Toplam Araç: {0}'}" />
                </Border>
            </Grid>
        </Border>

        <ItemsControl Grid.Row="2"
                      ItemsSource="{Binding Apps}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="2" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type viewModels:AppCardViewModel}">
                    <Border Margin="0,0,18,18"
                            Padding="24"
                            Background="White"
                            BorderBrush="#E5E7EB"
                            BorderThickness="1"
                            CornerRadius="26"
                            Effect="{StaticResource CardShadow}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Width="58"
                                        Height="58"
                                        Background="{Binding AccentSoftBrush}"
                                        CornerRadius="18">
                                    <Viewbox Width="26"
                                             Height="26"
                                             Margin="16">
                                        <Path Fill="{Binding AccentBrush}"
                                              Data="M 6,0 L 20,0 26,6 26,20 20,26 6,26 0,20 0,6 Z" />
                                    </Viewbox>
                                </Border>

                                <StackPanel Grid.Column="1"
                                            Margin="18,0,0,0">
                                    <TextBlock FontSize="24"
                                               FontFamily="Bahnschrift SemiBold"
                                               Foreground="#0F172A"
                                               Text="{Binding Definition.DisplayName}" />
                                    <TextBlock Margin="0,8,0,0"
                                               Foreground="#475569"
                                               TextWrapping="Wrap"
                                               Text="{Binding Definition.Description}" />
                                </StackPanel>
                            </Grid>

                            <StackPanel Grid.Row="1"
                                        Margin="0,18,0,0"
                                        Orientation="Horizontal">
                                <Border Padding="10,6"
                                        CornerRadius="999"
                                        Background="{Binding AccentSoftBrush}">
                                    <TextBlock Foreground="{Binding AccentBrush}"
                                               FontWeight="SemiBold"
                                               Text="{Binding StatusText}" />
                                </Border>
                                <Border Margin="10,0,0,0"
                                        Padding="10,6"
                                        Background="#EEF2FF"
                                        CornerRadius="999"
                                        Visibility="{Binding HasUpdateAvailable, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Foreground="#4338CA"
                                               FontWeight="SemiBold"
                                               Text="Yeni sürüm var" />
                                </Border>
                            </StackPanel>

                            <Grid Grid.Row="2"
                                  Margin="0,18,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Margin="0,0,10,0"
                                        Padding="14"
                                        Background="#F8FAFC"
                                        CornerRadius="16">
                                    <StackPanel>
                                        <TextBlock Foreground="#64748B"
                                                   FontSize="12"
                                                   Text="Kurulu Sürüm" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Foreground="#0F172A"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding InstalledVersion}" />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1"
                                        Padding="14"
                                        Background="#F8FAFC"
                                        CornerRadius="16">
                                    <StackPanel>
                                        <TextBlock Foreground="#64748B"
                                                   FontSize="12"
                                                   Text="Son Bilinen Release" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Foreground="#0F172A"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding LatestVersion}" />
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <StackPanel Grid.Row="3"
                                        Margin="0,18,0,0">
                                <TextBlock Foreground="#64748B"
                                           FontSize="12"
                                           Text="Son Kontrol" />
                                <TextBlock Margin="0,6,0,0"
                                           Foreground="#0F172A"
                                           Text="{Binding LastCheckedText}" />

                                <TextBlock Margin="0,18,0,0"
                                           Foreground="#64748B"
                                           FontSize="12"
                                           Text="Kurulum Yolu" />
                                <TextBlock Margin="0,6,0,0"
                                           Foreground="#0F172A"
                                           TextWrapping="Wrap"
                                           Text="{Binding InstalledPath}" />

                                <Border Margin="0,18,0,0"
                                        Padding="12"
                                        Background="#FEF2F2"
                                        CornerRadius="14"
                                        Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <StackPanel>
                                        <TextBlock Foreground="#B91C1C"
                                                   FontWeight="SemiBold"
                                                   Text="Son Hata" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Foreground="#7F1D1D"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding LastError}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <Button Grid.Row="4"
                                    Margin="0,24,0,0"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Background="{Binding AccentBrush}"
                                    Content="{Binding ActionText}"
                                    Command="{Binding DataContext.OpenAppCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <TextBlock Grid.Row="3"
                   Margin="4,8,0,0"
                   Foreground="#64748B"
                   Text="Launcher açık kalır; araçlar ayrı süreç olarak çalışır ve güncellemeler launcher üzerinden yönetilir." />
    </Grid>
</Window>

