<Window x:Class="RaporAraclari.Launcher.Views.UpdatePromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Güncelleme Var"
        Width="420"
        Height="280"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#FFF9F5">
    <Border Margin="20"
            Padding="24"
            CornerRadius="20"
            Background="White"
            BorderBrush="#E5E7EB"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Text="{Binding TitleText}"
                       FontSize="24"
                       FontFamily="Bahnschrift SemiBold"
                       Foreground="#0F172A" />

            <TextBlock Grid.Row="1"
                       Margin="0,14,0,0"
                       Text="{Binding SummaryText}"
                       TextWrapping="Wrap"
                       Foreground="#334155"
                       FontSize="14" />

            <Border Grid.Row="2"
                    Margin="0,18,0,0"
                    Padding="14"
                    CornerRadius="14"
                    Background="{Binding AccentSoftBrush}">
                <StackPanel>
                    <TextBlock Text="{Binding DetailText}"
                               FontWeight="SemiBold"
                               Foreground="#0F172A" />
                    <TextBlock Margin="0,8,0,0"
                               Text="{Binding AssetText}"
                               Foreground="#475569" />
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="3"
                        Margin="0,18,0,0"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Width="110"
                        Margin="0,0,10,0"
                        Padding="12,8"
                        Content="Daha Sonra"
                        Click="LaterButton_OnClick" />
                <Button Width="110"
                        Padding="12,8"
                        Content="Güncelle"
                        Background="{Binding AccentBrush}"
                        Foreground="White"
                        BorderThickness="0"
                        Click="UpdateButton_OnClick" />
            </StackPanel>
        </Grid>
    </Border>
</Window>

