<Window x:Class="RaporAraclari.Launcher.Views.UpdatePromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Güncelleme"
        Width="430"
        Height="260"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Icon="pack://application:,,,/Assets/icon.ico">
    <Border Margin="15"
            Padding="20"
            CornerRadius="8"
            Background="{StaticResource CardBg}"
            BorderBrush="{StaticResource BorderColor}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Text="{Binding TitleText}"
                       FontSize="18"
                       FontWeight="SemiBold" />

            <TextBlock Grid.Row="1"
                       Margin="0,6,0,0"
                       Text="{Binding VersionText}"
                       Foreground="{StaticResource AccentColor}"
                       FontSize="12"
                       FontWeight="SemiBold" />

            <TextBlock Grid.Row="2"
                       Margin="0,14,0,0"
                       Text="{Binding SummaryText}"
                       TextWrapping="Wrap"
                       Foreground="{StaticResource TextSecondary}"
                       FontSize="12" />

            <Border Grid.Row="3"
                    Margin="0,16,0,0"
                    Padding="12"
                    CornerRadius="6"
                    BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="1"
                    Background="{StaticResource SurfaceMuted}">
                <StackPanel>
                    <TextBlock Text="Kurulum Bilgisi"
                               Foreground="{StaticResource TextSecondary}"
                               FontSize="10" />
                    <TextBlock Margin="0,4,0,0"
                               Text="{Binding AssetText}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="4"
                        Margin="0,18,0,0"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Width="110"
                        Margin="0,0,10,0"
                        Padding="12,8"
                        Content="Daha Sonra"
                        Click="LaterButton_OnClick" />
                <Button Width="110"
                        Padding="12,8"
                        Content="Güncelle"
                        Style="{StaticResource AccentButton}"
                        Click="UpdateButton_OnClick" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
